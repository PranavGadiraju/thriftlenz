# eBay Developer application credentials.
# Use Sandbox keys with EBAY_ENV=sandbox while testing.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=production

# Optional catalogue controls.
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_DELIVERY_COUNTRY=US
EBAY_SEARCH_QUERY=vintage clothing

# Optional visual-search recognition.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
